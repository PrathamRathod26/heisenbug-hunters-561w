# Copy to .env and fill in.
# docker compose picks up values from .env automatically.

# Postgres (shared by backend + postgres service)
DB_USER=postgres
DB_PASSWORD=change-me
DB_NAME=claims

# Port the Angular SPA is reachable on from the host
FRONTEND_PORT=80

# CORS allow-list for the backend (comma-separated).
# For same-host deploy with nginx reverse proxy you rarely need this,
# but set it if the SPA is ever served from a different origin.
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80

# GPT-4o key used by ml-services/gpt_assessment.py.
# Omit and the surveyor assessment is returned as null (degraded analysis).
OPENAI_API_KEY=

# Hugging Face token for the YOLOv11 car-damage model download.
# Required only if the model repo is private; leave empty for public mirrors.
HF_TOKEN=
