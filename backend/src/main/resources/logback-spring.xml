<?xml version="1.0" encoding="UTF-8"?>
<!--
  Spring-profile-aware Logback config.
    dev,default -> human-readable console; package-level tweaks come from application-dev.yml
    qa,uat      -> structured JSON (logstash) to stdout + async-rolling JSON file
    prod        -> structured JSON (logstash) to stdout only; container runtime ships to Loki (TSD §5.17)
  Structured JSON format is resolved from the `logging.structured.format.console|file` properties
  in application-{profile}.yml via Spring Boot's StructuredLogEncoder (no extra dependency).
-->
<configuration>

    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <springProfile name="dev,default">
        <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <springProfile name="qa,uat">
        <include resource="org/springframework/boot/logging/logback/structured-console-appender.xml"/>
        <include resource="org/springframework/boot/logging/logback/structured-file-appender.xml"/>

        <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
            <queueSize>4096</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <neverBlock>true</neverBlock>
            <includeCallerData>false</includeCallerData>
            <appender-ref ref="FILE"/>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
        </root>
    </springProfile>

    <springProfile name="prod">
        <include resource="org/springframework/boot/logging/logback/structured-console-appender.xml"/>
        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.heisenbug.claims" level="INFO"/>
    </springProfile>

    <logger name="org.apache.catalina" level="INFO"/>
    <logger name="org.apache.coyote" level="INFO"/>
    <logger name="org.apache.tomcat" level="INFO"/>
    <logger name="org.springframework.boot.autoconfigure" level="INFO"/>
    <logger name="org.hibernate.orm.deprecation" level="ERROR"/>
</configuration>
